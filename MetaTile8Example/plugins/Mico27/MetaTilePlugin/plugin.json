{
  "type": "enginePlugin",
  "name": "Metatile Plugin",
  "author": "Mico27",
  "url": "https://github.com/Mico27/gbs-MetatilePlugin",
  "description": "Integrates the concept of metatiles in gbstudio",
  "license": "MIT",
  "version": "1.1.0",
  "gbsVersion": ">=4.2.2",
  "engineAltRules": [
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ConfigLoadSavePlugin",
          "Mico27/FadeStreetPlugin"
        ]
      },
      "use": "Conf_F"
    },
    {
      "when": {
        "additionalPlugins": [
          "ConfigLoadSavePlugin",
          "FadeStreetPlugin"
        ]
      },
      "use": "Conf_F"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/ConfigLoadSavePlugin"
        ]
      },
      "use": "Conf"
    },
    {
      "when": {
        "additionalPlugins": [
          "ConfigLoadSavePlugin"
        ]
      },
      "use": "Conf"
    },
    {
      "when": {
        "additionalPlugins": [
          "Mico27/FadeStreetPlugin"
        ]
      },
      "use": "F"
    },
    {
      "when": {
        "additionalPlugins": [
          "FadeStreetPlugin"
        ]
      },
      "use": "F"
    }
  ]
}