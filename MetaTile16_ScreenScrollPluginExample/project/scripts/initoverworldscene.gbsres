                                "true": [
                                  {
                                    "command": "EVENT_COMMENT",
                                    "args": {
                                      "text": "Compare player position in pixel to the current hole position in pixel",
                                      "__collapse": true
                                    },
                                    "id": "757ac7ea-d832-474e-9b9f-5d62a459213c"
                                  },
                                  {
                                    "command": "EVENT_COMMENT",
                                    "args": {
                                      "text": "if the player is right of it, we push the player left by changing velocity\nelse if the player is left of it, we push the player right by changing velocity",
                                      "__collapse": true
                                    },
                                    "id": "9a58d1c7-8b41-42c3-8e85-778b0a182705"
                                  },
