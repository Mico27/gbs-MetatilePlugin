                  "children": {
                    "true": [
                      {
                        "command": "EVENT_INC_VALUE",
                        "args": {
                          "variable": "15",
                          "__collapse": true
                        },
                        "id": "ec6b5b3d-c664-49d2-87aa-3485adfbe8be"
                      },
                      {
                        "command": "EVENT_COMMENT",
                        "args": {
                          "text": "We change the animation state of the actor to tripping\nand start a new thread with the loop that will pull the player\nin the hole",
                          "__collapse": true
                        },
                        "id": "568a9773-75cb-48f0-8367-c57cee7e9f5e"
                      },
                      {
                        "command": "EVENT_ACTOR_SET_STATE",
